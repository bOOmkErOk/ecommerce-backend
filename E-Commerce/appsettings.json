{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=ECommerce;Integrated Security=True;"
  },
  "JwtSettings": {
    "SigningKey": "SET_IN_USER_SECRETS",
    "Issuer": "E-Commerce",
    "Audience": "E-Commerce",
    "AccessTokenDays": 7
  },
  "AllowedHosts": "*"
}
